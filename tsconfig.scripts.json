{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "types": ["node"],
    "esModuleInterop": true,
    "allowImportingTsExtensions": true
  },
  "include": ["scripts", "supabase/functions/_shared"]
}
